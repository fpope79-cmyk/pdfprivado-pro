{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDFPrivado Pro",
  "version": "0.1.0",
  "identifier": "com.pdfprivado.pro",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "node scripts/prepare-frontend.mjs dev",
    "beforeBuildCommand": "node scripts/prepare-frontend.mjs release"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "PDFPrivado Pro",
        "width": 1280,
        "height": 820,
        "minWidth": 940,
        "minHeight": 660,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": [
          "pdf"
        ],
        "mimeType": "application/pdf",
        "name": "Documento PDF",
        "description": "Documento PDF",
        "role": "Editor",
        "rank": "Alternate"
      }
    ]
  }
}
